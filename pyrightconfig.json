{
  "exclude": [".venv", ".ruff_cache", "**/_not_used", "**/node_modules", "**/__pycache__"],

  "reportAny": "none",
  "reportExplicitAny": "none",
  "reportImplicitStringConcatenation": "none",
  "reportMissingParameterType": "none",
  "reportMissingTypeArgument": "none",
  "reportMissingTypeStubs": "none",
  "reportUnannotatedClassAttribute": "none",
  "reportUnknownMemberType": "none", // doesn't allow c.host
  "reportUnusedCallResult": "none" // forces ugly code like _ = subprocess.run(...).
}
